#!/usr/bin/with-contenv sh
# English: Loads Docker secrets as environment variables from /run/secrets.
# Deutsch: Lädt Docker-Secrets als Umgebungsvariablen aus /run/secrets.

set -e

if [ -d /run/secrets ]; then
  for secret in /run/secrets/*; do
    [ -f "$secret" ] || continue
    varname=$(basename "$secret" | tr '[:lower:]' '[:upper:]' | tr -c 'A-Z0-9_' '_')
    export "$varname"="$(cat "$secret")"
    echo "Loaded secret for variable: $varname"
  done
fi
